VITE_USE_MOCK=false
VITE_API_BASE_URL=/api/v1

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=truthlens

# 以下为遗留的 NewsAPI 演示采集（默认关闭）。正式采集请走百炼流水线等自建编排，写入 news 表。
NEWS_API_KEY=
NEWS_API_QUERY=China
NEWS_API_PAGE_SIZE=30
NEWS_API_ENDPOINT=https://newsapi.org/v2/everything
NEWS_COLLECT_ENABLED=false
NEWS_COLLECT_CRON=*/15 * * * *

# 单篇/多篇分析等调用的通义千问（DashScope）API，勿将真实 Key 提交到仓库
DASHSCOPE_API_KEY=

# 生产环境可配置允许的 Origin，逗号分隔（开发环境已放行 localhost 与常见私网段）
# CORS_ALLOWLIST=https://your-domain.com
